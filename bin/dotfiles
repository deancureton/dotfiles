#!/bin/zsh

# =============================================================================
# Dotfiles Management Script
# =============================================================================

BIN_NAME=$(basename "$0")
COMMAND_NAME=$1
SUB_COMMAND_NAME=$2

# =============================================================================
# Helper Functions
# =============================================================================

sub_help() {
  echo "Usage: $BIN_NAME <command>"
  echo
  echo "Commands:"
  echo "   help               This help message"
  echo "   stow [folder]      Stow config folder"
  echo "   edit               Open dotfiles in editor ($EDITOR)"
  echo "   clean              Clean up system + caches (mole, brew, pip, uv)"
  echo "   update             Update packages and pkg managers (via topgrade)"
  echo "   dump               Dump current Homebrew packages to Brewfile"
  echo "   macos              Apply macOS system defaults"
  echo "   dock               Apply OS X Dock settings"
  echo "   start              Start services (sketchybar, rift)"
  echo "   restart            Restart services (sketchybar, rift)"
}

sub_stow() {
  stow --dir=$DOTFILES_DIR/config --target=$HOME --verbose=1 --ignore='.DS_Store' $SUB_COMMAND_NAME
}

sub_dock() {
  . "${DOTFILES_DIR}/macos/dock.zsh" && echo "Dock reloaded."
}

sub_edit() {
  local editor="${EDITOR:-cursor}"
  if [ $SUB_COMMAND_NAME ]; then
    zsh -c "$SUB_COMMAND_NAME $DOTFILES_DIR"
  else
    zsh -c "$editor $DOTFILES_DIR"
  fi
}

sub_clean() {
  echo "$ mo clean"
  mo clean

  echo "$ brew cleanup --prune=all"
  brew cleanup --prune=all

  echo "$ pip3 cache purge"
  pip3 cache purge

  echo "$ uv cache clean"
  uv cache clean
}

sub_update() {
  echo "$ topgrade"
  topgrade
}

sub_dump() {
  echo "Dumping taps, formulae, and App Store apps to Brewfile..."
  echo "$ brew bundle dump --taps --formulae --mas --file=${DOTFILES_DIR}/install/Brewfile --force"
  brew bundle dump --taps --formulae --mas --file="${DOTFILES_DIR}/install/Brewfile" --force
  echo "Done! Brewfile updated at ${DOTFILES_DIR}/install/Brewfile"
  echo "Note: dump writes ALL leaves to Brewfile — re-sort niche tools into Extrabrewfile by hand."
  echo "(Casks and editor extensions are curated manually in Caskfile/Extracaskfile/Codefile.)"
}

sub_macos() {
  for DEFAULTS_FILE in "${DOTFILES_DIR}"/macos/defaults*.zsh; do
    echo "Applying ${DEFAULTS_FILE}" && . "${DEFAULTS_FILE}"
  done
  echo "Done. Some changes may require a logout/restart to take effect."
}

sub_start() {
  echo "Starting sketchybar, rift"
  echo "$ brew services start sketchybar"
  brew services start sketchybar
  echo "$ brew services start rift"
  brew services start rift
}

sub_restart() {
  echo "Restarting sketchybar, rift"
  echo "$ brew services restart sketchybar"
  brew services restart sketchybar
  echo "$ brew services restart rift"
  brew services restart rift
}

# =============================================================================
# Main Command Router
# =============================================================================

case $COMMAND_NAME in
  "" | "-h" | "--help")
    sub_help
    ;;
  *)
    shift
    sub_${COMMAND_NAME} $@
    if [ $? = 127 ]; then
      echo "'$COMMAND_NAME' is not a known command or has errors." >&2
      sub_help
      exit 1
    fi
    ;;
esac
